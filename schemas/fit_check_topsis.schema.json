{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/fit_check_topsis.schema.json",
  "title": "Fit-check TOPSIS Decision Matrix",
  "type": "object",
  "required": ["altitude", "criteria", "options", "scores"],
  "additionalProperties": false,
  "properties": {
    "frame": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "decision_from_opportunity": {"type": "string"},
        "decision_statement": {"type": "string"},
        "situation_context": {"type": "string"},
        "last_real_episode": {"type": "string"},
        "baseline_today": {"type": "string"},
        "old_way": {"type": "string"},
        "trigger_forcing_function": {"type": "string"},
        "constraints_misfits": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "desired_outcome": {"type": "string"},
        "desired_improvement": {"type": "string"},
        "success_criteria": {
          "oneOf": [
            {"type": "string"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "rejected_alternatives": {
          "oneOf": [
            {"type": "string"},
            {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name"],
                "properties": {
                  "name": {"type": "string"},
                  "reason_rejected": {"type": "string"}
                }
              }
            }
          ]
        }
      }
    },
    "altitude": {
      "type": "object",
      "required": ["comparable"],
      "additionalProperties": false,
      "properties": {
        "statement": {"type": "string"},
        "comparison_type": {
          "type": "string",
          "enum": ["parent_opportunities", "sibling_child_opportunities", "solution_paths", "experiments", "spikes", "other"]
        },
        "comparable": {"type": "boolean"},
        "notes": {"type": "string"}
      }
    },
    "scale": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min": {"type": "number", "default": 0},
        "max": {"type": "number", "default": 2},
        "labels": {
          "type": "object",
          "additionalProperties": {"type": ["string", "number"]}
        }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "must_points": {"type": "number", "default": 5},
        "nice_points": {"type": "number", "default": 1},
        "near_tie_threshold": {"type": "number", "default": 0.05},
        "rank_disqualified": {"type": "boolean", "default": false}
      }
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "category": {
            "type": "string",
            "enum": ["fitness", "cost", "risk", "compatibility_complexity", "purpose_built", "other"]
          },
          "priority": {"type": "string", "enum": ["must", "nice"]},
          "points": {"type": "number"},
          "weight": {"type": "number", "minimum": 0},
          "direction": {"type": "string", "enum": ["benefit", "cost"], "default": "benefit"},
          "is_must": {"type": "boolean"},
          "disqualifying_score": {"type": "number"}
        }
      }
    },
    "options": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "option_type": {"type": "string", "enum": ["opportunity", "solution_path", "experiment", "spike", "other"]},
          "assumptions": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "scores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["option_id", "criterion_id", "aspect_note", "score"],
        "additionalProperties": false,
        "properties": {
          "option_id": {"type": "string"},
          "criterion_id": {"type": "string"},
          "aspect_note": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S",
            "not": {
              "pattern": "^\\s*[-+]?(?:\\d+(?:\\.\\d*)?|\\.\\d+)\\s*$"
            }
          },
          "score": {"type": "number"},
          "color": {"type": "string", "enum": ["red", "yellow", "green", "Red", "Yellow", "Green"]},
          "uncertainty_note": {"type": "string"}
        }
      }
    }
  }
}
